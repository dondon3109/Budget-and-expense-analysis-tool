# Browser-facing API URL. Leave blank in local development to use the Vite proxy.
VITE_API_URL=

# Public Supabase browser configuration (Project Settings > API).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Comma-separated origins accepted by the API.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Worker-side JWT verification. This URL must match VITE_SUPABASE_URL.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
