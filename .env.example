# Optional browser-facing API override. Leave blank in local development to use the Vite proxy.
# Production defaults to https://api.zoption.site via apps/web/.env.production.
VITE_API_URL=

# Public Supabase browser configuration (Project Settings > API).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Comma-separated origins accepted by the API. Keep the Pages origin during migration.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://zoption.site,https://www.zoption.site,https://clarity-budget.pages.dev

# Worker-side JWT verification. This URL must match VITE_SUPABASE_URL.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
